# NEXUS-II v2.1 — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ── Anthropic ─────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── DhanHQ (broker) ───────────────────────────────────────────────────────
DHAN_ACCESS_TOKEN=your_dhan_access_token
DHAN_CLIENT_ID=your_dhan_client_id

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key          # Dashboard (Next.js) only — Python bot uses SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Cloudflare (CI/CD only — set as GitHub Secrets for Cloudflare Workers deploy) ──
CF_API_TOKEN=your_cloudflare_api_token            # CI/CD only — not needed for local bot
CF_ACCOUNT_ID=your_cloudflare_account_id          # CI/CD only — not needed for local bot

# ── External Data ─────────────────────────────────────────────────────────
FRED_API_KEY=                         # From fred.stlouisfed.org/docs/api/api_key.html (free)
ALPHA_VANTAGE_API_KEY=                # From alphavantage.co/support/ (free: 25 req/day)
FINNHUB_API_KEY=                     # From finnhub.io (free tier available)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key          # Used by DataTools for FOREX (USD/INR) and commodity (Brent crude) data
OPENBB_PAT=your_openbb_pat                         # Planned — OpenBB integration not yet active in current codebase

# ── NSE Data ──────────────────────────────────────────────────────────────
NSE_SESSION_COOKIE=                                # Optional: NSE website session cookie for advanced market breadth endpoints
                                                   # (advance/decline ratio, FII breakdown). Leave blank to use public endpoints only.

# ── Trading Capital ───────────────────────────────────────────────────────
STARTING_CAPITAL=100000                            # Starting capital in INR. Used by DrawdownMonitor, PreTradeRiskChecker,
                                                   # and MCPTools for position sizing. Example: ₹1,00,000

# ── Trading Mode ──────────────────────────────────────────────────────────
# PAPER_TRADE | LIVE
TRADING_MODE=PAPER_TRADE

# ── Brain / Qlib ──────────────────────────────────────────────────────────
NEXUS_QLIB_NATIVE=                                 # Set to "1" to enable native Qlib ML scoring pipeline.
                                                   # Requires a fully configured Qlib environment with trained models.
NEXUS_MODEL_REGISTRY_PATH=                         # Optional: absolute path to custom model registry directory.
                                                   # Leave blank to auto-detect (project-relative ./models/).

# ── System ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TZ=Asia/Kolkata
