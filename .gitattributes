# NEXUS-II — Git line ending normalisation
# Ensures LF in repo, OS-native on checkout (CRLF on Windows, LF on Unix)
* text=auto

# Force LF for all source files (keeps diffs clean across OS)
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.sh    text eol=lf

# Binary — never mangle
*.png   binary
*.jpg   binary
*.pkl   binary
*.model binary
